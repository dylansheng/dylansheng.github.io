source "https://rubygems.org"

# Stack compatible with macOS system Ruby 2.6 (no Homebrew Ruby required).
gem "jekyll", "~> 3.9"
gem "jekyll-remote-theme"
gem "jekyll-sass-converter", "~> 1.5"
gem "kramdown-parser-gfm"
gem "webrick", "~> 1.8"
# Pin ffi so Bundler does not pick a Ruby 3+–only native gem on older Ruby.
gem "ffi", "~> 1.15.0"
